#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VERSION_FILE="$REPO_DIR/VERSION"

# shellcheck source=libexec/_common
. "$REPO_DIR/libexec/_common"

if [[ ! -f "$VERSION_FILE" ]]; then
    printf 'Error: VERSION file not found: %s\n' "$VERSION_FILE" >&2
    exit 1
fi

version="$(< "$VERSION_FILE")"

# Release builds require a plain SemVer (X.Y.Z) from the VERSION file.
if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    printf 'Error: VERSION does not contain a valid SemVer: "%s"\n' "$version" >&2
    exit 1
fi

# dist/ is a pristine release artifact — always rebuild from scratch.
rm -rf "$REPO_DIR/dist"

dotfiles_build "$REPO_DIR" 'dist' "$version"

printf 'Dist complete (version %s).\n' "$version"
