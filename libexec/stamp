#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CHANGELOG_FILE="$REPO_DIR/CHANGELOG.md"

# Stamp a new release section into CHANGELOG.md, listing commits since the last
# tag under a versioned heading. The [Unreleased] section is kept above it.

version="${1:-}"

if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    printf 'Error: invalid version "%s". Expected a SemVer (X.Y.Z).\n' "$version" >&2
    exit 1
fi

if [[ ! -f "$CHANGELOG_FILE" ]]; then
    printf 'Error: CHANGELOG.md not found: %s\n' "$CHANGELOG_FILE" >&2
    exit 1
fi

if ! grep -q '^## \[Unreleased\]' "$CHANGELOG_FILE"; then
    printf 'Error: CHANGELOG.md has no "## [Unreleased]" section.\n' >&2
    exit 1
fi

date="$(date +%F)"
entries="$("$REPO_DIR/libexec/changelog")"

# Fall back to a placeholder when there are no commits since the last tag.
[[ -n "$entries" ]] || entries='- No notable changes.'

section="## [$version] - $date"$'\n\n'"$entries"

# Insert the new section immediately after the [Unreleased] heading.
awk -v block="$section" '
    { print }
    /^## \[Unreleased\]/ && !done {
        print ""
        print block
        done = 1
    }
' "$CHANGELOG_FILE" > "${CHANGELOG_FILE}.tmp"
mv "${CHANGELOG_FILE}.tmp" "$CHANGELOG_FILE"

printf 'Stamped CHANGELOG.md with version %s.\n' "$version"
