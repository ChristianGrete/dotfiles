#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Orchestrate a release (Model B): bump VERSION, stamp CHANGELOG.md, commit the
# source changes to the current branch, then build a pristine dist/ into a
# separate build commit that is referenced only by the signed tag. The branch
# is reset back to the source commit so it stays free of generated code.
#
# This script does NOT push. The caller (release workflow or user) pushes the
# branch and the tag afterwards.

level="${1:-}"

if [[ "$level" != 'patch' && "$level" != 'minor' && "$level" != 'major' ]]; then
    printf 'Error: invalid release level "%s". Use "patch", "minor", or "major".\n' "$level" >&2
    exit 1
fi

# 1. Bump VERSION and read the resulting SemVer.
"$REPO_DIR/libexec/bump" "$level"
version="$(< "$REPO_DIR/VERSION")"

# 2. Stamp CHANGELOG.md with the new version and commits since the last tag.
"$REPO_DIR/libexec/stamp" "$version"

# 3. Commit the source changes (VERSION + CHANGELOG.md) to the current branch.
git -C "$REPO_DIR" add VERSION CHANGELOG.md
git -C "$REPO_DIR" commit -m "bump(version): $version"
release_commit="$(git -C "$REPO_DIR" rev-parse HEAD)"

# 4. Build the pristine dist/ artifact.
"$REPO_DIR/libexec/dist"

# 5. Commit the build artifact (force-add, since dist/ is gitignored).
git -C "$REPO_DIR" add -f dist
git -C "$REPO_DIR" commit -m "build(dist): v$version"

# 6. Sign-tag the build commit.
git -C "$REPO_DIR" tag -s "v$version" -m "release(tag): $version"

# 7. Reset the branch back to the source commit. The build commit survives as a
#    dangling commit referenced only by the tag, keeping the branch clean.
git -C "$REPO_DIR" reset --hard "$release_commit"

printf 'release: tagged v%s on the branch %s.\n' "$version" "$(git -C "$REPO_DIR" rev-parse --abbrev-ref HEAD)"
printf 'release: push the branch and the tag to publish.\n'
