#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VERSION_FILE="$REPO_DIR/VERSION"

# Determine the bump level (patch, minor, or major).
level="${1:-}"

if [[ "$level" != 'patch' && "$level" != 'minor' && "$level" != 'major' ]]; then
  printf 'Error: invalid bump level "%s". Use "patch", "minor", or "major".\n' "$level" >&2
  exit 1
fi

if [[ ! -f "$VERSION_FILE" ]]; then
  printf 'Error: VERSION file not found: %s\n' "$VERSION_FILE" >&2
  exit 1
fi

current="$(< "$VERSION_FILE")"

# Validate the current version is a plain SemVer (X.Y.Z).
if [[ ! "$current" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  printf 'Error: VERSION does not contain a valid SemVer: "%s"\n' "$current" >&2
  exit 1
fi

IFS='.' read -r major minor patch <<< "$current"

case "$level" in
  major) major=$((major + 1)); minor=0; patch=0 ;;
  minor) minor=$((minor + 1)); patch=0 ;;
  patch) patch=$((patch + 1)) ;;
esac

next="${major}.${minor}.${patch}"

printf '%s\n' "$next" > "$VERSION_FILE"

printf 'Bumped version: %s -> %s\n' "$current" "$next"
