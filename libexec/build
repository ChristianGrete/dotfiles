#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=libexec/_common
. "$REPO_DIR/libexec/_common"

# Dev builds are identified by the current git short commit hash.
version="$(git -C "$REPO_DIR" rev-parse --short HEAD 2> '/dev/null' || printf 'unknown')"

dotfiles_build "$REPO_DIR" 'build' "$version"

printf 'Build complete.\n'